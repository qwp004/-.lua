    icon.TextSize = 22
    icon.ZIndex = 14
    icon.Parent = btn

    local name = Instance.new("TextLabel")
    name.Size = UDim2.new(1, -45, 1, 0)
    name.Position = UDim2.new(0, 40, 0, 0)
    name.BackgroundTransparency = 1
    name.Text = page.name
    name.Font = Enum.Font.GothamBold
    name.TextSize = 14
    name.TextColor3 = Color3.fromRGB(255, 255, 255)
    name.TextXAlignment = Enum.TextXAlignment.Left
    name.ZIndex = 14
    name.Parent = btn

    local ind = Instance.new("Frame")
    ind.Size = UDim2.new(0, 3, 0.6, 0)
    ind.Position = UDim2.new(0, 0, 0.2, 0)
    ind.BackgroundColor3 = page.color
    ind.BorderSizePixel = 0
    ind.ZIndex = 14
    ind.Visible = false
    corner(ind, 2)
    ind.Parent = btn

    btn.MouseEnter:Connect(function()
        if currentPage ~= page then tween(btn, {BackgroundColor3 = Colors.HoverBg}, 0.2) end
    end)

    btn.MouseLeave:Connect(function()
        if currentPage ~= page then tween(btn, {BackgroundColor3 = Colors.ButtonBg}, 0.2) end
    end)

    btn.MouseButton1Click:Connect(function()
        if currentPage then
            for _, c in pairs(SidebarScroll:GetChildren()) do
                if c:IsA("TextButton") and c ~= btn then
                    tween(c, {BackgroundColor3 = Colors.ButtonBg}, 0.3)
                    c:FindFirstChildOfClass("Frame").Visible = false
                end
            end
        end

        currentPage = page
        tween(btn, {BackgroundColor3 = Colors.ActiveBg}, 0.3)
        ind.Visible = true

        for _, c in pairs(ContentScroll:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then c:Destroy() end
        end

        page.build(ContentScroll)
        ContentScroll.CanvasSize = UDim2.new(0, 0, 0, ContentList.AbsoluteContentSize.Y + 20)
    end)

    btn.Parent = SidebarScroll
end

