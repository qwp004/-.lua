-- 工具函数
local function corner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 20)
    c.Parent = parent
    return c
end

local function glow(parent, color, size)
    local g = Instance.new("UIStroke")
    g.Color = color or Colors.Accent
    g.Thickness = size or 2
    g.Transparency = 0.3
    g.Parent = parent
    return g
end

local function tween(obj, props, dur)
    TweenService:Create(obj, TweenInfo.new(dur or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

