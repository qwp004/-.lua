-- 飞行
local flyBody = nil
local flyConn = nil

local function updateFly()
    if flyConn then
        pcall(function() flyConn:Disconnect() end)
        flyConn = nil
    end
    if flyBody then
        pcall(function() flyBody:Destroy() end)
        flyBody = nil
    end

    if not State.fly.enabled then return end

    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    flyBody = Instance.new("BodyVelocity")
    flyBody.MaxForce = Vector3.new(400000, 400000, 400000)
    flyBody.Velocity = Vector3.new(0, 0, 0)
    flyBody.Parent = hrp

    flyConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if not flyBody or not flyBody.Parent then return end
            local char = player.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChild("Humanoid")
            if not hrp or not humanoid then return end

            local camCF = camera.CFrame
            local vel = Vector3.new(0, 0, 0)

            if State.fly.mobile then
                -- 手机虚拟摇杆
                local moveDir = humanoid.MoveDirection
                if moveDir.Magnitude > 0.1 then
                    local forward = camCF.LookVector * Vector3.new(1, 0, 1)
                    if forward.Magnitude > 0 then forward = forward.Unit end
                    local right = camCF.RightVector * Vector3.new(1, 0, 1)
                    if right.Magnitude > 0 then right = right.Unit end

                    vel = (forward * -moveDir.Z + right * moveDir.X) * State.fly.speed

                    if moveDir.Z < -0.8 then
                        vel = vel + Vector3.new(0, State.fly.speed * 0.3, 0)
                    elseif moveDir.Z > 0.8 then
                        vel = vel - Vector3.new(0, State.fly.speed * 0.3, 0)
                    end
                end

                if UserInputService:IsKeyDown(Enum.KeyCode.Space) or humanoid.Jump then
                    vel = vel + Vector3.new(0, State.fly.speed, 0)
                end
            else
                -- PC键盘
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + camCF.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - camCF.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - camCF.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + camCF.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.new(0, 1, 0) end
                vel = vel * State.fly.speed
            end

            flyBody.Velocity = vel
        end)
    end)
end

-- 玩家透视
local playerEspItems = {}
local function updatePlayerEsp()
    for _, item in pairs(playerEspItems) do
        pcall(function() item:Destroy() end)
    end
    playerEspItems = {}

    if not State.playerEsp.enabled then return end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            if State.playerEsp.teamCheck and p.Team == player.Team then continue end

            pcall(function()
                local highlight = Instance.new("Highlight")
                highlight.FillColor = Colors.Primary
                highlight.OutlineColor = Colors.Gold
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0
                highlight.Parent = p.Character
                table.insert(playerEspItems, highlight)

                local head = p.Character:FindFirstChild("Head")
                if head then
                    local bill = Instance.new("BillboardGui")
                    bill.Size = UDim2.new(0, 120, 0, 40)
                    bill.StudsOffset = Vector3.new(0, 2, 0)
                    bill.AlwaysOnTop = true
                    bill.Parent = head

                    local name = Instance.new("TextLabel")
                    name.Size = UDim2.new(1, 0, 0.5, 0)
                    name.BackgroundTransparency = 1
                    name.Text = p.Name
                    name.Font = Enum.Font.GothamBold
                    name.TextSize = 12
                    name.TextColor3 = Colors.Primary
                    name.Parent = bill

                    table.insert(playerEspItems, bill)
                end
            end)
        end
    end
end

-- NPC透视
local npcEspItems = {}
local function updateNpcEsp()
    for _, item in pairs(npcEspItems) do
        pcall(function() item:Destroy() end)
    end
    npcEspItems = {}

    if not State.npcEsp.enabled then return end

    local function processNpc(npc)
        if not npc:IsA("Model") then return end
        if not npc:FindFirstChild("Humanoid") then return end
        if Players:GetPlayerFromCharacter(npc) then return end

        pcall(function()
            local highlight = Instance.new("Highlight")
            highlight.FillColor = Colors.Red
            highlight.OutlineColor = Colors.Gold
            highlight.FillTransparency = 0.6
            highlight.OutlineTransparency = 0
            highlight.Parent = npc
            table.insert(npcEspItems, highlight)

            local head = npc:FindFirstChild("Head") or npc:FindFirstChild("HumanoidRootPart")
            if head then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0, 150, 0, 50)
                bill.StudsOffset = Vector3.new(0, 2, 0)
                bill.AlwaysOnTop = true
                bill.Parent = head

                local name = Instance.new("TextLabel")
                name.Size = UDim2.new(1, 0, 0.6, 0)
                name.BackgroundTransparency = 1
                name.Text = npc.Name
                name.Font = Enum.Font.GothamBold
                name.TextSize = 12
                name.TextColor3 = Colors.Red
                name.Parent = bill

                table.insert(npcEspItems, bill)
            end
        end)
    end

    for _, npc in pairs(Workspace:GetDescendants()) do
        processNpc(npc)
    end
end

-- 道具透视
local itemEspItems = {}
local lastItemUpdate = 0

local function updateItemEsp()
    for _, item in pairs(itemEspItems) do
        pcall(function() item:Destroy() end)
    end
    itemEspItems = {}

    if not State.itemEsp.enabled then return end

    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local myPos = char.HumanoidRootPart.Position

    local keywords = {"coin", "gem", "item", "tool", "weapon", "potion", "food", "money", "cash", "collect", "pickup", "loot", "drop", "reward", "chest", "box", "crate"}
    local count = 0

    for _, obj in pairs(Workspace:GetDescendants()) do
        if count >= 50 then break end
        if not obj:IsA("BasePart") and not obj:IsA("MeshPart") then continue end

        local isItem = false
        local name = string.lower(obj.Name)
        for _, kw in ipairs(keywords) do
            if string.find(name, kw) then
                isItem = true
                break
            end
        end

        if not isItem and (obj:FindFirstChild("ClickDetector") or obj:FindFirstChild("ProximityPrompt")) then
            isItem = true
        end

        if isItem then
            local dist = (obj.Position - myPos).Magnitude
            if dist <= State.itemEsp.range then
                pcall(function()
                    local highlight = Instance.new("Highlight")
                    highlight.FillColor = Colors.Green
                    highlight.OutlineColor = Colors.Accent
                    highlight.FillTransparency = 0.7
                    highlight.OutlineTransparency = 0.2
                    highlight.Parent = obj
                    table.insert(itemEspItems, highlight)

                    local bill = Instance.new("BillboardGui")
                    bill.Size = UDim2.new(0, 120, 0, 35)
                    bill.StudsOffset = Vector3.new(0, 1.5, 0)
                    bill.AlwaysOnTop = true
                    bill.Parent = obj

                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1, 0, 1, 0)
                    label.BackgroundTransparency = 1
                    label.Text = obj.Name .. "
" .. string.format("%.0fm", dist)
                    label.Font = Enum.Font.GothamBold
                    label.TextSize = 10
                    label.TextColor3 = Colors.Green
                    label.Parent = bill

                    table.insert(itemEspItems, bill)
                end)
                count = count + 1
            end
        end
    end
end

