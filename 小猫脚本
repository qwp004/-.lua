local npcKillConn = nil
local function updateNpcKill()
    if npcKillConn then
        pcall(function() npcKillConn:Disconnect() end)
        npcKillConn = nil
    end

    if not State.npcKill.enabled then return end

    npcKillConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local myPos = char.HumanoidRootPart.Position

            for _, npc in pairs(Workspace:GetDescendants()) do
                if not npc:IsA("Model") then continue end
                if not npc:FindFirstChild("Humanoid") then continue end
                if Players:GetPlayerFromCharacter(npc) then continue end

                local hrp = npc:FindFirstChild("HumanoidRootPart")
                local humanoid = npc:FindFirstChild("Humanoid")
                if hrp and humanoid then
                    local dist = (myPos - hrp.Position).Magnitude
                    if dist <= State.npcKill.range then
                        humanoid.Health = 0
                    end
                end
            end
        end)
        wait(State.npcKill.interval)
    end)
end

